# Keep attributes stable across Windows worktrees
.gitattributes text eol=lf
.editorconfig text eol=lf

# Windows batch files must use CRLF line endings
*.bat text eol=crlf

# Shell scripts should use LF line endings
*.sh text eol=lf

# Frontend HTML is generated and diff-checked; keep it LF on Windows too
*.html text eol=lf
